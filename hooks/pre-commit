#!/bin/bash
# pre-commit hook : enregistre une verification horodatee dans suivi/commitInfo.txt

read -p "Commit verifie (y/[n]) ? " yn < /dev/tty
yn=${yn:-n}

case $yn in
    [Yy]* )
        mkdir -p suivi
        echo "commit verifie le $(date '+%d/%m/%Y %H:%M:%S')" > suivi/commitInfo.txt
        git add suivi/commitInfo.txt
        exit 0;;
    * )
        exit 0;;
esac

exit 0
